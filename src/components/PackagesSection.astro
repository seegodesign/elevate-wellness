---
import { Icon } from 'astro-icon/components';

const packages = [
  {
    name: 'Individual Massage',
    duration: '60 or 90 minutes',
    features: [
      'Swedish or Deep Tissue',
      'Aromatherapy oils included',
      'Customized pressure',
      'Hot towel treatment',
      'Calming music',
    ],
    popular: false,
  },
  {
    name: 'Couples Massage',
    duration: '60 or 90 minutes',
    features: [
      'Side-by-side experience',
      'Two licensed therapists',
      'Aromatherapy & hot towels',
      'Champagne upgrade available',
      'Perfect for special occasions',
    ],
    popular: true,
  },
  {
    name: 'Beach Experience',
    duration: '90 minutes',
    features: [
      'Beachfront setup',
      'Ocean sounds & breeze',
      'Professional massage table',
      'Coconut oil treatment',
      'Truly unique experience',
    ],
    popular: false,
  },
];
---

<section class="relative">
  <div class="h-8"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <div class="text-center mb-16">
      <p class="text-[var(--blue-gray)] tracking-widest uppercase mb-4">Popular Options</p>
      <h2 class="text-4xl md:text-6xl mb-6" style="font-family: var(--font-serif)">
        Choose Your Perfect Session
      </h2>
      <p class="text-xl text-[var(--muted-foreground)] max-w-2xl mx-auto">
        Approachable wellness for everyone. Each session is personalized to your needs.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
      {packages.map((pkg, i) => (
        <div
          data-intersect
          class={`relative bg-white rounded-3xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 opacity-0 translate-y-4 intersect:opacity-100 intersect:translate-y-0 ${pkg.popular ? 'ring-2 ring-[var(--sage)] scale-105 md:scale-110' : 'hover:scale-105'} ${i === 1 ? 'delay-150' : i === 2 ? 'delay-300' : ''}`}
          style="transition-duration: 700ms"
        >
          {pkg.popular && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-[var(--sage)] text-white px-6 py-2 rounded-full shadow-lg">
              Most Popular
            </div>
          )}
          <div class="text-center mb-6 mt-2">
            <h3 class="text-2xl mb-2" style="font-family: var(--font-serif)">{pkg.name}</h3>
            <p class="text-[var(--muted-foreground)]">{pkg.duration}</p>
          </div>
          <ul class="space-y-4 mb-8">
            {pkg.features.map(feature => (
              <li class="flex items-start gap-3">
                <div class="flex-shrink-0 w-5 h-5 rounded-full bg-[var(--sage)]/20 flex items-center justify-center mt-0.5">
                  <Icon name="lucide:check" class="w-3 h-3 text-[var(--sage)]" />
                </div>
                <span class="text-[var(--charcoal)]">{feature}</span>
              </li>
            ))}
          </ul>
          <a
            href="/book"
            class={`block w-full py-3 rounded-full text-center transition-all duration-300 ${pkg.popular ? 'bg-[var(--sage)] text-white hover:bg-[var(--sage-dark)] shadow-lg' : 'bg-[var(--ocean)] text-white hover:bg-[var(--ocean-light)]'}`}
          >
            Reserve Now
          </a>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <p class="text-[var(--muted-foreground)]">
        All sessions include consultation and personalized treatment.{' '}
        <a href="/#contact" class="text-[var(--ocean)] hover:underline">Contact us</a> for custom packages.
      </p>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 z-10">
    <svg viewBox="0 0 1440 99" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
      <path d="M0 40C180 60 360 80 540 75C720 70 900 40 1080 30C1260 20 1380 30 1410 35L1440 40V100H0V40Z" fill="#FDFBF7" fill-opacity="0.6"></path>
      <path d="M0 60C180 75 360 90 540 85C720 80 900 50 1080 40C1260 30 1380 40 1410 45L1440 50V100H0V60Z" fill="#FDFBF7"></path>
    </svg>
  </div>
</section>
