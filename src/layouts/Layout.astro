---
import '../styles/index.css';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Elevate Wellness Kauai',
  description = 'Premium massage and wellness services in Kauai. Couples massage, mobile therapy, and beachside experiences.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/webp" href="/favicon.webp" />
  </head>
  <body>
    <slot />
    <script src="https://link.msgsndr.com/js/form_embed.js"></script>
    <script src="https://widgets.leadconnectorhq.com/loader.js" data-resources-url="https://widgets.leadconnectorhq.com/chat-widget/loader.js" data-widget-id="69f1dc85191334a877471f05"></script>
    <script>
      // Intersection observer for scroll-triggered animations.
      // Adds .is-intersecting to elements with data-intersect attribute,
      // enabling the intersect: Tailwind variant defined in theme.css.
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-intersecting');
            }
          });
        },
        { threshold: 0.1 }
      );
      document.querySelectorAll('[data-intersect]').forEach(el => observer.observe(el));
    </script>
  </body>
</html>
