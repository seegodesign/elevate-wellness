---
import { Icon } from 'astro-icon/components';
import logo from '../imports/elevate-logo.png';

const year = new Date().getFullYear();

const services = [
  { name: 'Couples Massage', href: '/#services' },
  { name: 'Mobile Massage', href: '/#services' },
  { name: 'Beachside Massage', href: '/#services' },
];
const company = [
  { name: 'About Us', href: '/#about' },
  { name: 'Testimonials', href: '/#testimonials' },
  { name: 'Book Now', href: '/book' },
  { name: 'Contact', href: '/#contact' },
];
const areas = [
  { name: "Princeville", href: '#' },
  { name: "Kapa'a", href: '#' },
  { name: 'Lihue', href: '#' },
  { name: 'Poipu', href: '#' },
];
---

<footer class="bg-[var(--charcoal)] text-white relative">
  <div class="absolute top-0 left-0 right-0 z-10">
    <svg viewBox="0 0 1440 79" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full transform rotate-180">
      <path d="M0 20L120 30C240 40 480 60 720 60C960 60 1200 40 1320 30L1440 20V80H0V20Z" fill="#F5EFE7"></path>
    </svg>
  </div>

  <div class="max-w-7xl mx-auto px-6 lg:px-12 pt-24 pb-16 relative z-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12 mb-12">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <img src={logo.src} alt="Elevate Wellness Kauai" class="h-16 w-auto mb-4" />
        <p class="text-white/70 mb-6 leading-relaxed">
          Premium massage and wellness services in Kauai. Specializing in couples massage, mobile therapy, and beachside experiences.
        </p>
        <div class="flex gap-4">
          <a href="#" class="w-10 h-10 rounded-full bg-white/10 hover:bg-[var(--sage)] flex items-center justify-center transition-colors duration-300">
            <Icon name="lucide:instagram" class="w-5 h-5" />
          </a>
          <a href="#" class="w-10 h-10 rounded-full bg-white/10 hover:bg-[var(--sage)] flex items-center justify-center transition-colors duration-300">
            <Icon name="lucide:facebook" class="w-5 h-5" />
          </a>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h4 class="mb-4" style="font-family: var(--font-serif)">Services</h4>
        <ul class="space-y-3">
          {services.map(item => (
            <li>
              <a href={item.href} class="text-white/70 hover:text-[var(--sage)] transition-colors duration-200">{item.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="mb-4" style="font-family: var(--font-serif)">Company</h4>
        <ul class="space-y-3">
          {company.map(item => (
            <li>
              <a href={item.href} class="text-white/70 hover:text-[var(--sage)] transition-colors duration-200">{item.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Service Areas -->
      <div>
        <h4 class="mb-4" style="font-family: var(--font-serif)">Service Areas</h4>
        <ul class="space-y-3">
          {areas.map(item => (
            <li>
              <a href={item.href} class="text-white/70 hover:text-[var(--sage)] transition-colors duration-200">{item.name}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Contact Info -->
    <div class="border-t border-white/10 pt-8 pb-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="flex items-center gap-3">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-[var(--sage)]/20 flex items-center justify-center">
            <Icon name="lucide:phone" class="w-5 h-5 text-[var(--sage)]" />
          </div>
          <div>
            <p class="text-sm text-white/60">Call or Text</p>
            <a href="tel:808-555-0123" class="hover:text-[var(--sage)] transition-colors">(808) 555-0123</a>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-[var(--sage)]/20 flex items-center justify-center">
            <Icon name="lucide:mail" class="w-5 h-5 text-[var(--sage)]" />
          </div>
          <div>
            <p class="text-sm text-white/60">Email</p>
            <a href="mailto:info@elevatewellnesskauai.com" class="hover:text-[var(--sage)] transition-colors">info@elevatewellnesskauai.com</a>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-[var(--sage)]/20 flex items-center justify-center">
            <Icon name="lucide:map-pin" class="w-5 h-5 text-[var(--sage)]" />
          </div>
          <div>
            <p class="text-sm text-white/60">Based in</p>
            <p>Kapa'a, Kauai, HI</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom -->
    <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-white/60 text-sm">© {year} Elevate Wellness Kauai. All rights reserved.</p>
      <div class="flex gap-6 text-sm">
        <a href="#" class="text-white/60 hover:text-[var(--sage)] transition-colors">Privacy Policy</a>
        <a href="#" class="text-white/60 hover:text-[var(--sage)] transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
