---
import { Icon } from 'astro-icon/components';
---

<section class="flex-1 bg-[var(--sand)] py-16">
  <div class="max-w-5xl mx-auto px-6 lg:px-12">
    <!-- Location Picker -->
    <div class="text-center mb-8">
      <p class="text-[var(--charcoal)]/60 text-sm uppercase tracking-widest mb-4">
        Where would you like your massage?
      </p>
      <div class="inline-flex rounded-2xl bg-[var(--charcoal)]/10 border border-[var(--charcoal)]/20 p-1.5 gap-1.5">
        <button
          data-location="indoor"
          aria-pressed="true"
          class="flex items-center gap-2 px-7 py-4 rounded-xl font-semibold text-base transition-all duration-300 text-[var(--charcoal)]/70 hover:text-[var(--charcoal)] hover:bg-[var(--charcoal)]/10 aria-pressed:bg-[var(--sage)] aria-pressed:text-white aria-pressed:shadow-lg aria-pressed:scale-105"
        >
          <Icon name="lucide:building-2" class="w-5 h-5" />
          Indoor Studio
        </button>
        <button
          data-location="oceanfront"
          aria-pressed="false"
          class="flex items-center gap-2 px-7 py-4 rounded-xl font-semibold text-base transition-all duration-300 text-[var(--charcoal)]/70 hover:text-[var(--charcoal)] hover:bg-[var(--charcoal)]/10 aria-pressed:bg-[var(--ocean)] aria-pressed:text-white aria-pressed:shadow-lg aria-pressed:scale-105"
        >
          <Icon name="lucide:waves" class="w-5 h-5" />
          Oceanfront
        </button>
      </div>
    </div>

    <!-- GHL Iframes -->
    <div class="rounded-2xl overflow-hidden">
      <iframe
        data-location="indoor"
        src="https://api.leadconnectorhq.com/widget/group/r41cRr67i4wvr0I75paj"
        style="width: 100%; min-height: 800px; border: none; overflow: hidden;"
        scrolling="no"
        id="r41cRr67i4wvr0I75paj_1777359498865"
      ></iframe>
      <iframe
        data-location="oceanfront"
        src="https://api.leadconnectorhq.com/widget/group/001OycXJ4NA6CvB4nMFU"
        style="width: 100%; min-height: 800px; border: none; overflow: hidden;"
        scrolling="no"
        id="001OycXJ4NA6CvB4nMFU_booking_page"
        class="hidden"
      ></iframe>
    </div>
  </div>
</section>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('button[data-location]');
  const frames = document.querySelectorAll<HTMLIFrameElement>('iframe[data-location]');

  function setLocation(location: string) {
    buttons.forEach(btn => {
      btn.setAttribute('aria-pressed', btn.dataset.location === location ? 'true' : 'false');
    });
    frames.forEach(frame => {
      frame.classList.toggle('hidden', frame.dataset.location !== location);
    });
  }

  buttons.forEach(btn => {
    btn.addEventListener('click', () => setLocation(btn.dataset.location!));
  });
</script>
