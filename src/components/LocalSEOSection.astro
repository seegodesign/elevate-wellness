---
import { Icon } from 'astro-icon/components';
---

<section class="relative py-24 bg-[#F5EFE7]">
  <div class="relative z-10 max-w-5xl mx-auto px-6 lg:px-12">
    <div class="text-center mb-12 text-[var(--charcoal)]">
      <h2 class="text-4xl md:text-5xl mb-3" style="font-family: var(--font-serif)">
        Serving All of Kauai
      </h2>
      <p class="text-[var(--muted-foreground)] text-lg">Based in Kapa'a · Mobile Service Island-Wide</p>
    </div>

    <div class="max-w-3xl mx-auto text-center mb-24">
      <p class="text-[var(--muted-foreground)] leading-relaxed mb-4">
        Elevate Wellness Kauai proudly offers premium <strong class="text-[var(--blue-gray)]">massage services in Kauai</strong>, specializing in <strong class="text-[var(--blue-gray)]">couples massage</strong>, <strong class="text-[var(--blue-gray)]">mobile massage therapy</strong>, and unique <strong class="text-[var(--blue-gray)]">beachside massage experiences</strong>. Based in <strong class="text-[var(--blue-gray)]">Kapa'a</strong>, we provide convenient mobile services throughout the island, from Princeville to Poipu.
      </p>
      <p class="text-[var(--muted-foreground)] leading-relaxed">
        Whether you're staying in Princeville, Hanalei, Kapaa, Lihue, Koloa, or Poipu, our licensed massage therapists bring professional wellness services directly to you. From <strong class="text-[var(--blue-gray)]">relaxing Swedish massage</strong> to <strong class="text-[var(--blue-gray)]">therapeutic deep tissue</strong>, we customize every session to meet your needs.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="flex flex-col items-center text-center gap-4">
        <div class="w-26 h-26 rounded-full bg-[var(--ocean)]/10 flex items-center justify-center">
          <Icon name="lucide:map-pin" class="w-12 h-12 text-[var(--ocean)]" />
        </div>
        <div>
          <h4 class="text-[var(--charcoal)] mb-1 text-4xl">Service Areas</h4>
          <p class="text-[var(--muted-foreground)] text-md">
            Princeville · Hanalei · Kapa'a · Lihue · Koloa · Poipu
          </p>
        </div>
      </div>

      <div class="flex flex-col items-center text-center gap-4">
        <div class="w-26 h-26 rounded-full bg-[var(--ocean)]/10 flex items-center justify-center">
          <Icon name="lucide:phone" class="w-12 h-12 text-[var(--ocean)]" />
        </div>
        <div>
          <h4 class="text-[var(--charcoal)] mb-1 text-4xl">Call or Text</h4>
          <p class="text-[var(--muted-foreground)] text-md"><a href="tel:8085550123">(808) 555-0123</a></p>
        </div>
      </div>

      <div class="flex flex-col items-center text-center gap-4">
        <div class="w-26 h-26 rounded-full bg-[var(--ocean)]/10 flex items-center justify-center">
          <Icon name="lucide:mail" class="w-12 h-12 text-[var(--ocean)]" />
        </div>
        <div>
          <h4 class="text-[var(--charcoal)] mb-1 text-4xl">Email Us</h4>
          <p class="text-[var(--muted-foreground)] text-md"><a href="mailto:info@elevatewellnesskauai.com">info@elevatewellnesskauai.com</a></p>
        </div>
      </div>
    </div>
  </div>
</section>
