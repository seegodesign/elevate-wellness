---
import { Icon } from 'astro-icon/components';

const basicFeatures = [
  'Issues resolved within 24 hours',
  'Bug fixes & content updates',
  'Email & messaging support',
  'Monthly performance check',
];

const premiumFeatures = [
  'Everything in Basic Support',
  '2-hour emergency response',
  'Dedicated account manager',
  'Weekly performance reports',
  'Priority feature requests',
  'Quarterly strategy call',
];
---

<section class="py-24 bg-[var(--sand)]">
  <div class="max-w-5xl mx-auto px-6 lg:px-12">
    <div class="text-center mb-14">
      <p class="text-[var(--blue-gray)] tracking-widest uppercase mb-4">Website Maintenance</p>
      <h2 class="text-4xl md:text-5xl mb-5" style="font-family: var(--font-serif)">
        We've Got You Covered
      </h2>
      <p class="text-xl text-[var(--muted-foreground)] max-w-2xl mx-auto">
        Every plan includes peace-of-mind support so your site stays running perfectly.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Basic Support -->
      <div
        data-intersect
        class="bg-white rounded-3xl p-10 shadow-lg border border-[var(--border)] opacity-0 translate-y-4 transition-all duration-700 intersect:opacity-100 intersect:translate-y-0"
      >
        <div class="mb-6">
          <p class="text-[var(--sage)] font-semibold uppercase tracking-widest text-sm mb-2">
            Included with all plans
          </p>
          <h3 class="text-3xl mb-2" style="font-family: var(--font-serif)">Basic Support</h3>
          <p class="text-[var(--muted-foreground)]">Standard coverage included at no extra cost.</p>
        </div>
        <ul class="space-y-4 mb-8">
          {basicFeatures.map(item => (
            <li class="flex items-start gap-3">
              <div class="flex-shrink-0 w-5 h-5 rounded-full bg-[var(--sage)]/20 flex items-center justify-center mt-0.5">
                <Icon name="lucide:check" class="w-3 h-3 text-[var(--sage)]" />
              </div>
              <span class="text-[var(--charcoal)]">{item}</span>
            </li>
          ))}
        </ul>
        <div class="pt-6 border-t border-[var(--border)]">
          <p class="text-2xl font-semibold text-[var(--charcoal)]">
            Included <span class="text-base font-normal text-[var(--muted-foreground)]">/ free with your plan</span>
          </p>
        </div>
      </div>

      <!-- Premium Support -->
      <div
        data-intersect
        class="bg-[var(--charcoal)] rounded-3xl p-10 shadow-xl text-white relative overflow-hidden opacity-0 translate-y-4 transition-all duration-700 delay-150 intersect:opacity-100 intersect:translate-y-0"
      >
        <div class="absolute top-6 right-6 bg-[var(--sage)] text-white text-xs font-semibold px-3 py-1 rounded-full">Upgrade</div>
        <div class="absolute -bottom-16 -right-16 w-56 h-56 bg-white/5 rounded-full"></div>
        <div class="mb-6 relative z-10">
          <div class="flex items-center gap-2 mb-2">
            <Icon name="lucide:zap" class="w-4 h-4 text-[var(--sage)]" />
            <p class="text-[var(--sage)] font-semibold uppercase tracking-widest text-sm">Premium</p>
          </div>
          <h3 class="text-3xl mb-2" style="font-family: var(--font-serif)">Priority Support</h3>
          <p class="text-white/60">White-glove care for businesses that can't afford downtime.</p>
        </div>
        <ul class="space-y-4 mb-8 relative z-10">
          {premiumFeatures.map(item => (
            <li class="flex items-start gap-3">
              <div class="flex-shrink-0 w-5 h-5 rounded-full bg-[var(--sage)]/30 flex items-center justify-center mt-0.5">
                <Icon name="lucide:check" class="w-3 h-3 text-[var(--sage)]" />
              </div>
              <span class="text-white/80">{item}</span>
            </li>
          ))}
        </ul>
        <div class="pt-6 border-t border-white/10 relative z-10">
          <p class="text-3xl font-semibold">
            $497<span class="text-lg font-normal text-white/50"> / mo</span>
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
