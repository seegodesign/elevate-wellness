---
import { Icon } from 'astro-icon/components';
---

<section class="py-24 bg-gradient-to-br from-[var(--ocean)] via-[var(--blue-gray)] to-[var(--sage)] text-white relative overflow-hidden">
  <div class="absolute top-20 right-10 w-96 h-96 bg-white/5 rounded-full blur-3xl"></div>
  <div class="absolute bottom-20 left-10 w-72 h-72 bg-[var(--sage)]/20 rounded-full blur-3xl"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-12 relative z-10">
    <div class="text-center mb-16">
      <p class="text-white tracking-widest uppercase mb-4">Easy Booking</p>
      <h2 class="text-4xl md:text-6xl mb-6" style="font-family: var(--font-serif)">Reserve Your Session</h2>
      <p class="text-xl text-white/80 max-w-2xl mx-auto">
        Book online in minutes or call us directly. Same-day appointments often available.
      </p>
    </div>

    <!-- Booking Steps -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-16">
      {[
        { icon: 'lucide:calendar', title: 'Select Service', desc: 'Choose from couples massage, mobile service, or beachside experience' },
        { icon: 'lucide:clock', title: 'Choose Time', desc: 'Pick a date and time that works for your schedule' },
        { icon: 'lucide:map-pin', title: 'Location', desc: 'Provide your hotel, rental, or preferred beach location' },
        { icon: 'lucide:credit-card', title: 'Confirm', desc: 'Secure your booking with easy payment options' },
      ].map((step, index) => (
        <div class="text-center relative">
          {index < 3 && (
            <div class="hidden md:block absolute top-8 left-[60%] w-[80%] h-0.5 bg-white/20">
              <div class="absolute right-0 top-1/2 -translate-y-1/2 w-2 h-2 bg-white/40 rounded-full"></div>
            </div>
          )}
          <div class="mb-4 inline-flex items-center justify-center">
            <div class="relative">
              <div class="absolute inset-0 bg-white/20 rounded-full blur-xl"></div>
              <div class="relative bg-white/10 backdrop-blur-sm p-6 rounded-full border-2 border-white/30">
                <Icon name={step.icon} class="w-8 h-8 text-white" />
              </div>
            </div>
          </div>
          <h3 class="text-xl mb-2" style="font-family: var(--font-serif)">{step.title}</h3>
          <p class="text-white/70 text-sm leading-relaxed">{step.desc}</p>
        </div>
      ))}
    </div>

    <!-- Book Now CTA -->
    <div class="text-center">
      <a
        href="/book"
        class="inline-flex items-center gap-3 px-10 py-5 bg-white text-[var(--ocean)] rounded-full text-lg font-semibold shadow-xl hover:shadow-2xl hover:scale-105 transition-all duration-300"
      >
        <Icon name="lucide:calendar" class="w-5 h-5" />
        Book Now
      </a>
      <p class="mt-4 text-white/60 text-sm">Same-day appointments often available</p>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 z-10">
    <svg viewBox="0 0 1440 99" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
      <path d="M0 20C240 70 480 90 720 90C960 90 1200 70 1440 20V100H0V20Z" fill="#F5EFE7" fill-opacity="0.5"></path>
      <path d="M0 40C240 80 480 100 720 100C960 100 1200 80 1440 40V100H0V40Z" fill="#F5EFE7"></path>
    </svg>
  </div>
</section>
