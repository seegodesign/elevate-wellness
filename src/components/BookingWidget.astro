---
import { Icon } from "astro-icon/components";
---

<section class="flex-1 bg-[var(--sand)] py-16">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <!-- Location Picker -->
    <div class="text-center mb-8">
      <p
        class="text-[var(--charcoal)]/60 text-sm uppercase tracking-widest mb-4"
      >
        Where would you like your massage?
      </p>
      <div
        class="inline-flex rounded-2xl bg-[var(--charcoal)]/10 border border-[var(--charcoal)]/20 p-1.5 gap-1.5"
      >
        <button
          data-location="indoor"
          aria-pressed="true"
          class="flex items-center gap-2 px-7 py-4 rounded-xl font-semibold text-base transition-all duration-300 text-[var(--charcoal)]/70 hover:text-[var(--charcoal)] hover:bg-[var(--charcoal)]/10 aria-pressed:bg-[var(--sage)] aria-pressed:text-white aria-pressed:shadow-lg aria-pressed:scale-105"
        >
          <Icon name="lucide:building-2" class="w-5 h-5" />
          Indoor Studio
        </button>
        <button
          data-location="oceanfront"
          aria-pressed="false"
          class="flex items-center gap-2 px-7 py-4 rounded-xl font-semibold text-base transition-all duration-300 text-[var(--charcoal)]/70 hover:text-[var(--charcoal)] hover:bg-[var(--charcoal)]/10 aria-pressed:bg-[var(--ocean)] aria-pressed:text-white aria-pressed:shadow-lg aria-pressed:scale-105"
        >
          <Icon name="lucide:waves" class="w-5 h-5" />
          Oceanfront
        </button>
      </div>
    </div>

    <!-- GHL Iframes -->
    <div class="rounded-2xl overflow-hidden">
      <div data-location="indoor">
        <iframe
          src="https://api.leadconnectorhq.com/widget/service-menu/69f05213f0ebe72fd28ef3c2"
          style="width: 100%;border:none;overflow: hidden;"
          scrolling="no"
          id="69f05213f0ebe72fd28ef3c2_1777463228500"
        ></iframe>
      </div>
      <div data-location="oceanfront" class="hidden">
        <iframe
          src="https://api.leadconnectorhq.com/widget/service-menu/69f1e62f7a5b5e3aa6438e4c"
          style="width: 100%;border:none;overflow: hidden;"
          scrolling="no"
          id="69f1e62f7a5b5e3aa6438e4c_1777463239172"
        ></iframe>
      </div>
    </div>
  </div>
</section>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(
    "button[data-location]",
  );
  const containers =
    document.querySelectorAll<HTMLDivElement>("div[data-location]");

  function setLocation(location: string) {
    buttons.forEach((btn) => {
      btn.setAttribute(
        "aria-pressed",
        btn.dataset.location === location ? "true" : "false",
      );
    });
    containers.forEach((container) => {
      container.classList.toggle(
        "hidden",
        container.dataset.location !== location,
      );
    });
  }

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => setLocation(btn.dataset.location!));
  });
</script>
