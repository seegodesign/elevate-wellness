---
import { serviceCategories } from '../app/data/services';
---

<section class="py-24 bg-[var(--charcoal)] relative" id="services">
  <div class="max-w-7xl mx-auto px-6 pb-20 lg:px-12">
    <div
      data-intersect
      class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12 opacity-0 translate-y-6 transition-all duration-700 intersect:opacity-100 intersect:translate-y-0"
    >
      <div>
        <p class="text-[var(--orange)] tracking-widest uppercase text-sm mb-3">What We Offer</p>
        <h2 class="text-4xl md:text-6xl text-white leading-tight" style="font-family: var(--font-serif)">
          Every body. Every setting.
        </h2>
      </div>
      <p class="text-white/50 max-w-xs md:text-right leading-relaxed">
        From private rooms to open beaches — tailored wellness wherever you are on Kauai.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      {serviceCategories.map((category, i) => (
        <div
          data-intersect
          class={`flex flex-col overflow-hidden rounded-2xl opacity-0 translate-y-8 transition-all duration-700 intersect:opacity-100 intersect:translate-y-0 ${i === 1 ? 'delay-150' : i === 2 ? 'delay-300' : ''}`}
        >
          <div class="relative h-52 overflow-hidden">
            <img src={category.image} alt={category.title} class="absolute inset-0 w-full h-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-b from-black/20 to-black/70"></div>
            <div class="absolute top-5 left-5">
              <span class="text-xs tracking-widest uppercase text-white/80 bg-white/10 backdrop-blur-sm px-3 py-1 rounded-full border border-white/10">
                {category.tag}
              </span>
            </div>
            <div class="absolute bottom-5 left-5 right-5">
              <h3 class="text-2xl text-white" style="font-family: var(--font-serif)">{category.title}</h3>
              <p class="text-white/60 text-sm mt-1 leading-relaxed">{category.description}</p>
            </div>
          </div>
          <div class="bg-white/5 border border-white/10 border-t-0 rounded-b-2xl p-5 flex-1 flex flex-col">
            <ul class="columns-2 gap-x-4 space-y-2.5 flex-1">
              {category.services.map(service => (
                <li class="flex items-start gap-2 break-inside-avoid">
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-[var(--orange)] shrink-0"></span>
                  <span class="text-white/80 text-sm leading-snug">
                    {service.name}
                    {service.note && (
                      <span class="block text-[var(--orange)] text-xs mt-0.5">{service.note}</span>
                    )}
                  </span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 z-10">
    <svg viewBox="0 0 1440 99" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
      <path d="M0 80C240 20 480 0 720 0C960 0 1200 20 1440 80V100H0V80Z" fill="var(--warm-white)"></path>
    </svg>
  </div>
</section>
