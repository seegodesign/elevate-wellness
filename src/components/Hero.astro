---
import heroBgVideo from '../imports/12453948-hd_1280_720_30fps.mp4';
---

<section class="relative h-screen min-h-[700px] flex items-center justify-center">
  <!-- Background Video -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-gradient-to-br from-[var(--orange)]/70 via-[var(--ocean)]/50 to-[var(--sage)]/20 z-10"></div>
    <video
      class="absolute inset-0 w-full h-full object-cover"
      src={heroBgVideo}
      autoplay
      loop
      muted
      playsinline
      aria-hidden="true"
    ></video>
  </div>

  <!-- Content -->
  <div class="relative z-20 max-w-7xl mx-auto px-6 lg:px-12 text-center">
    <!-- Stars badge -->
    <div class="motion-preset-fade-up flex flex-col items-center justify-center gap-2 mb-6">
      <div class="flex gap-1">
        {Array.from({ length: 5 }).map(() => (
          <svg class="w-5 h-5 fill-[var(--yellow)] text-[var(--yellow)]" viewBox="0 0 24 24">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        ))}
      </div>
      <div class="text-white/90 tracking-wide">Voted #1 Wellness Service in Kapa'a on TripAdvisor</div>
    </div>

    <h1
      class="motion-preset-fade-up motion-delay-150 text-5xl md:text-7xl text-white mb-6"
      style="font-family: var(--font-serif)"
    >
      Kauai's Top-rated<br />
      Wellness Experiences
    </h1>

    <p class="motion-preset-fade-up motion-delay-300 text-xl md:text-2xl text-white/90 mb-12 max-w-3xl mx-auto leading-relaxed">
      Couples massage, mobile services, and oceanside experiences — tailored wellness wherever you are on Kauai.
    </p>

    <div class="motion-preset-fade-up motion-delay-500 flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a
        href="/book"
        class="px-10 py-4 bg-[var(--sage)] text-white rounded-full hover:bg-[var(--sage-dark)] transition-all duration-300 shadow-2xl hover:shadow-[var(--sage)]/50 hover:scale-105"
      >
        Book Now
      </a>
      <a
        href="/#services"
        class="px-10 py-4 bg-white/10 backdrop-blur-md text-white rounded-full border-2 border-white/30 hover:bg-white/20 transition-all duration-300"
      >
        View Services
      </a>
    </div>
  </div>
</section>
